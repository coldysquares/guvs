#!/usr/bin/env python3
import json
import re
import sys
import subprocess
from html import escape
from pathlib import Path

def slugify(text):
    slug = re.sub(r"[^a-z0-9]+", "-", text.lower()).strip("-")
    return slug or "new-guv"

title = sys.argv[1].strip() if len(sys.argv) > 1 else input("GUV title: ").strip()
description = sys.argv[2].strip() if len(sys.argv) > 2 else input("Short description: ").strip()

if not title:
    print("No title given.")
    sys.exit(1)

slug = slugify(title)
folder = Path(slug)
page = folder / "index.html"
registry_path = Path("registry.json")

if folder.exists():
    print(f"Folder already exists: {slug}")
    sys.exit(1)

registry = json.loads(registry_path.read_text())

if any(item.get("slug") == slug or item.get("path") == f"{slug}/" for item in registry):
    print(f"Registry already has this GUV: {slug}")
    sys.exit(1)

folder.mkdir()

page.write_text(f"""<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{escape(title)}</title>
  <style>
    body {{
      margin: 0;
      min-height: 100vh;
      background: #070808;
      color: #e8eeee;
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      line-height: 1.5;
    }}
    main {{
      width: min(820px, calc(100% - 32px));
      margin: 0 auto;
      padding: 64px 0;
    }}
    a {{ color: #b7fff4; }}
    .muted {{ color: #9aa7a7; }}
  </style>
</head>
<body>
  <main>
    <p><a href="../">← Back to GUVs</a></p>
    <h1>{escape(title)}</h1>
    <p class="muted">{escape(description)}</p>

    <hr />

    <p>Replace this page with the actual GUV HTML.</p>
  </main>
</body>
</html>
""")

registry.append({
    "title": title,
    "fullName": title,
    "slug": slug,
    "type": ["GUV"],
    "status": "draft",
    "path": f"{slug}/",
    "description": description
})

registry_path.write_text(json.dumps(registry, indent=2) + "\n")

print(f"Created: {slug}/index.html")
print(f"Added to registry.json")
print("")
print("Next:")
print(f"  code {slug}/index.html")
print("  ./publish \"Add " + slug + "\"")

try:
    subprocess.run(["code", str(page)])
except Exception:
    pass
