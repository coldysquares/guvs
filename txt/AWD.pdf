<!DOCTYPE html>
<html>
<head>
<title>AWD Gateway</title>
<style>
  body { font-family: monospace; background: #111; color: #0f0; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
  .box { width: 400px; padding: 20px; border: 1px solid #333; background: #000; box-shadow: 0 4px 15px rgba(0,255,0,0.1); }
  h3 { margin-top: 0; font-size: 14px; letter-spacing: 2px; }
  textarea { width: 95%; height: 80px; background: #111; color: #0f0; border: 1px solid #333; margin-bottom: 15px; padding: 10px; font-family: monospace; resize: none; }
  textarea:focus { outline: none; border-color: #0f0; }
  button { background: #222; color: #0f0; border: 1px solid #333; padding: 10px; cursor: pointer; font-family: monospace; width: 48%; margin-right: 2%; transition: 0.2s; }
  button:hover { background: #0f0; color: #000; }
  #char-count { font-size: 12px; color: #555; text-align: right; display: block; margin-top: -10px; margin-bottom: 15px; }
</style>
</head>
<body>
<div class="box">
  <h3>AWD // ZERO-WASTE ROUTER</h3>
  <textarea id="prompt" maxlength="280" placeholder="Type the delta... (Max 280 chars)"></textarea>
  <span id="char-count">0 / 280</span>
  <div>
    <button onclick="route('claude')">SEND // CLAUDE</button><button onclick="route('chatgpt')" style="margin-right:0;">SEND // GPT BURNER</button>
  </div>
</div>
<script>
  const ta = document.getElementById('prompt');
  const count = document.getElementById('char-count');
  ta.addEventListener('input', () => count.textContent = `${ta.value.length} / 280`);

  function route(dest) {
    let text = ta.value;
    if (!text) return;
    
    let sys = `CONTEXT: You are executing the AWD protocol.\nCONSTRAINT: Do not provide conversational filler. Adhere strictly to Zero-Waste Fidelity.\nUSER DELTA: ${text}`;
    let encoded = encodeURIComponent(sys);
    
    if (dest === 'claude') {
      window.open(`https://claude.ai/new?q=${encoded}`, '_blank');
    } else {
      window.open(`https://chatgpt.com/?q=${encoded}&temporary-chat=true`, '_blank');
    }
    ta.value = '';
    count.textContent = '0 / 280';
  }
</script>
</body>
</html>
