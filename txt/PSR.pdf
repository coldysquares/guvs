<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Semantic Triplet Generator</title>
  <style>
    :root {
      --bg: #0d0f12;
      --panel: #171a20;
      --text: #eceff4;
      --muted: #9aa4b2;
      --line: #2a3038;
      --accent: #d6ff6b;
      --danger: #ff7a7a;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
      background: radial-gradient(circle at top, #1b2028 0, var(--bg) 55%);
      color: var(--text);
      display: grid;
      place-items: center;
      padding: 24px;
    }

    main {
      width: min(860px, 100%);
      background: rgba(23, 26, 32, .92);
      border: 1px solid var(--line);
      border-radius: 20px;
      padding: 28px;
      box-shadow: 0 24px 80px rgba(0,0,0,.42);
    }

    h1 {
      margin: 0 0 8px;
      font-size: clamp(24px, 4vw, 42px);
      letter-spacing: -0.04em;
    }

    p {
      color: var(--muted);
      line-height: 1.45;
      margin: 0 0 24px;
    }

    #output {
      min-height: 104px;
      display: grid;
      place-items: center;
      text-align: center;
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 24px;
      margin: 18px 0;
      font-size: clamp(28px, 6vw, 56px);
      line-height: 1.05;
      letter-spacing: -0.06em;
      background: #0f1217;
    }

    .controls {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 18px;
    }

    button {
      appearance: none;
      border: 1px solid var(--line);
      background: #20252d;
      color: var(--text);
      border-radius: 999px;
      padding: 12px 16px;
      font: inherit;
      cursor: pointer;
    }

    button.primary {
      background: var(--accent);
      color: #111;
      border-color: transparent;
      font-weight: 700;
    }

    button.danger {
      border-color: rgba(255,122,122,.45);
      color: #ffd1d1;
    }

    button:hover { filter: brightness(1.08); }

    .prompt-box {
      border: 1px solid var(--line);
      background: #101319;
      border-radius: 16px;
      padding: 16px;
      margin-top: 12px;
    }

    .prompt-label {
      color: var(--muted);
      font-size: 13px;
      margin-bottom: 8px;
      text-transform: uppercase;
      letter-spacing: .08em;
    }

    #promptPreview {
      white-space: pre-wrap;
      line-height: 1.45;
      color: #dfe6f3;
      font-size: 14px;
    }

    .status {
      min-height: 20px;
      color: var(--accent);
      font-size: 13px;
      margin-top: 10px;
    }

    .history {
      margin-top: 22px;
      border-top: 1px solid var(--line);
      padding-top: 18px;
      color: var(--muted);
      font-size: 14px;
    }

    .history div {
      padding: 6px 0;
      border-bottom: 1px dashed rgba(255,255,255,.08);
    }
  </style>
</head>

<body>
  <main>
    <h1>Semantic Triplet Generator</h1>
    <p>Three unrelated, high-density words. Generate a collision, then copy either the raw triplet or a ready-to-paste AI Search prompt.</p>

    <div id="output">mycorrhizal byzantine tachyon</div>

    <div class="controls">
      <button class="primary" id="generate">generate</button>
      <button id="copyTriplet">copy triplet</button>
      <button id="copyCleanPrompt">copy clean prompt</button>
      <button class="danger" id="copyWildPrompt">copy wild prompt</button>
      <button id="chaos">chaos × 10</button>
    </div>

    <div class="prompt-box">
      <div class="prompt-label">AI Search prompt preview</div>
      <div id="promptPreview"></div>
      <div class="status" id="status"></div>
    </div>

    <div class="history" id="history"></div>
  </main>

  <script>
    const scientific = [
      "mycorrhizal","tachyonic","protocellular","chthonic","entropic","ribosomal","liminal",
      "cryogenic","neolithic","fractal","symbiotic","parthenogenic","fungible","spectral",
      "vectorized","anechoic","telomeric","hydrothermal","paleolithic","ferromagnetic",
      "isotopic","lithographic","autopoietic","synaptic","plasmidic","hyperbolic",
      "mitochondrial","quorum-sensing","ontogenetic","anaerobic","xenobiotic","alluvial",
      "catabolic","stochastic","phylogenetic","vesicular","epigenetic","lacunary"
    ];

    const cultural = [
      "byzantine","oracular","baroque","diasporic","cathar","vesuvian","babylonian",
      "gothic","sumerian","monastic","brutalist","appalachian","habsburg","delphic",
      "rajput","etruscan","weimar","occitan","carolingian","venetian","aztec","mamluk",
      "hanseatic","phoenician","talmudic","cybernetic","pynchonite","gnostic","jacobean",
      "saturnalian","ulster-scots","anatolian","hermetic","samizdat","mestizo","acheronian"
    ];

    const nouns = [
      "jurisprudence","tachyon","membrane","reliquary","substrate","cathedral","enzyme",
      "phantom","sigil","archive","organism","interface","glyph","machine","ritual",
      "cartography","psalm","chimera","protocol","fossil","mythos","signal","monolith",
      "vesicle","apparatus","weather","litany","palimpsest","molecule","diaspora",
      "sarcophagus","topology","codex","fugue","index","oracle","ecology","witness"
    ];

    let current = "mycorrhizal byzantine tachyon";

    function pick(arr) {
      return arr[Math.floor(Math.random() * arr.length)];
    }

    function triplet() {
      return `${pick(scientific)} ${pick(cultural)} ${pick(nouns)}`;
    }

    function cleanPrompt(value) {
      return `Treat these as unrelated terms: ${value}.

First define them separately. Then invent three plausible ways they could intersect without pretending the intersection is real. Clearly label what is factual, what is metaphorical, and what is speculative.`;
    }

    function wildPrompt(value) {
      return `Find the strongest hidden conceptual bridge between these three unrelated terms: ${value}.

Do not pretend a real field or historical connection exists unless there is evidence. Define each term separately, then produce:
1. the most honest factual reading,
2. the best metaphorical bridge,
3. the most interesting speculative sci-fi / literature premise,
4. a warning about where hallucination would likely creep in.`;
    }

    function updatePromptPreview() {
      document.getElementById("promptPreview").textContent = cleanPrompt(current);
    }

    function setStatus(text) {
      const status = document.getElementById("status");
      status.textContent = text;

      setTimeout(() => {
        if (status.textContent === text) {
          status.textContent = "";
        }
      }, 1400);
    }

    async function copyText(text, label) {
      await navigator.clipboard.writeText(text);
      setStatus(`copied: ${label}`);
    }

    function render(value) {
      current = value;
      document.getElementById("output").textContent = value;
      updatePromptPreview();

      const history = document.getElementById("history");
      const row = document.createElement("div");
      row.textContent = value;
      history.prepend(row);

      while (history.children.length > 12) {
        history.lastChild.remove();
      }
    }

    document.getElementById("generate").addEventListener("click", () => {
      render(triplet());
    });

    document.getElementById("copyTriplet").addEventListener("click", () => {
      copyText(current, "triplet");
    });

    document.getElementById("copyCleanPrompt").addEventListener("click", () => {
      copyText(cleanPrompt(current), "clean prompt");
    });

    document.getElementById("copyWildPrompt").addEventListener("click", () => {
      copyText(wildPrompt(current), "wild prompt");
    });

    document.getElementById("chaos").addEventListener("click", () => {
      for (let i = 0; i < 10; i++) {
        render(triplet());
      }
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === " " || e.key === "Enter") {
        e.preventDefault();
        render(triplet());
      }
    });

    updatePromptPreview();
  </script>
</body>
</html>